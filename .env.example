# ─────────────────────────────────────────────────────────────────────────────
# LedgerMind — variables d'environnement
# Copier en .env et adapter — NE JAMAIS committer .env
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme_dev_minimum_32_chars

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=changeme_dev_minimum_32_chars

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=ledgermind
MINIO_ROOT_PASSWORD=changeme_dev_minimum_32_chars

# ── Django ────────────────────────────────────────────────────────────────────
# Générer avec : python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_generate_with_secrets_token_urlsafe_64

# ── Domaine ───────────────────────────────────────────────────────────────────
# Dev  : localhost (accès http://api.localhost)
# Prod : votre domaine (ex: ledgermind.fr)
DOMAIN=localhost

# ── Registry Docker (prod uniquement) ─────────────────────────────────────────
DOCKER_REGISTRY=registry.example.com/ledgermind
IMAGE_TAG=latest

# ── Let's Encrypt (prod uniquement) ───────────────────────────────────────────
ACME_EMAIL=admin@ledgermind.fr

# ── Admin IP allowlist (prod) ─────────────────────────────────────────────────
# CIDR de confiance pour accès /admin/ — votre IP fixe ou VPN
ADMIN_IP_ALLOWLIST=127.0.0.1/32
